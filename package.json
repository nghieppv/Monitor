    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2",
    "mssql": "^9.0.1",
    "crypto-browserify": "^3.19.0",
    "stream-browserify": "^3.0.2",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@playwright/test": "^1.53.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
